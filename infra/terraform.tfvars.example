# Copy to terraform.tfvars and fill in your own values.
# terraform.tfvars is gitignored - never commit real values.

aws_region      = "us-east-1"
project_name    = "portfolio"
container_image = "yourdockerhubuser/portfolio:latest"
github_org      = "your-github-username"
github_repo     = "my-portfolio"

# HTTPS (optional). Leave both empty to serve HTTP-only on the ALB hostname.
# The domain must already exist as a public hosted zone in Route 53.
root_domain  = ""
app_hostname = ""
